*.gcno
*.pid
validation.json

# QEMU runtime artifacts — never commit
*.qcow2
*.sock
qemu.sock

# Publish-guard generated artifacts — never commit
.git-resolved-index

# Secret material -- never commit
/secrets/
/.env
/.env.*
*.pem
*.key
id_rsa
id_ed25519
