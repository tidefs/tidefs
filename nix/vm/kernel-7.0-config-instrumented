# ── Rust support ──────────────────────────────────────────────────────
MODULES y
RUST? y

# ── Debug / instrumentation ───────────────────────────────────────────
# Generic kernel debug
DEBUG_KERNEL y
DEBUG_INFO y
DEBUG_INFO_DWARF5 y

# ── Lockdep (CONFIG_PROVE_LOCKING) ───────────────────────────────────
PROVE_LOCKING y
DEBUG_LOCK_ALLOC y
LOCK_STAT y
LOCKDEP y
LOCKDEP_SMALL? y
DEBUG_LOCKING_API_SELFTESTS y

# ── KCSAN (Kernel Concurrency Sanitizer) ─────────────────────────────
KCSAN y
KCSAN_SELFTEST y
KCSAN_REPORT_VALUE_CHANGE_ONLY y
KCSAN_INTERRUPT_WATCHER y

# ── KASAN (Kernel Address Sanitizer) ─────────────────────────────────
KASAN? y
KASAN_GENERIC? y
KASAN_OUTLINE? y
KASAN_STACK? y
KASAN_VMALLOC? y

# ── KFENCE (low-overhead alternative, complementary to KASAN) ────────
