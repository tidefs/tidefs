# TideFS block-volume kernel module Kbuild.
#
# This file builds the tidefs-block-kmod crate as an out-of-tree
# Rust-for-Linux kernel module against Linux 7.0.
#
# Build command (from repo root):
#   make -j8 -C <linux-7.0-src> LLVM=1 O=<linux-7.0-build> M=crates/tidefs-block-kmod MO=<module-out> RUSTC=<rustc> RUSTC_BOOTSTRAP=1 modules
#
# Prerequisites:
#   - Linux 7.0 kernel build tree with CONFIG_RUST=y
#   - modules_prepare completed (builds rust/kernel.o, rust/pin_init.o, etc.)
#   - bindgen available for Rust binding generation
#   - rustc 1.78+ with rust-src component

obj-m := tidefs_block_kmod.o
