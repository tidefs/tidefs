#!/usr/bin/env bash
# tidefs-xfstests-mount — TideFS FUSE mount helper for xfstests
#
# xfstests calls this as: tidefs-preview <mountpoint> -o <options>
# (via mount.fuse which looks for TEST_DEV on PATH)
#
# The wrapper creates a per-mount backing store, launches the FUSE daemon,
# daemonizes it, and waits for the mountpoint to become ready.
set -euo pipefail

die() { echo "tidefs-xfstests-mount: $*" >&2; exit 1; }
debug() { [ "${TIDEFS_XFSTESTS_DEBUG:-0}" = "1" ] && echo "[tidefs-xfstests-mount] $*" >&2; return 0; }

# When called via mount(8): mount.fuse <device> <mountpoint> [-o opts]
# When called directly:      tidefs-preview <mountpoint> [-o opts]
# Detect calling convention by checking if $2 looks like a path.
if [ "$#" -ge 2 ] && [ "${2:0:1}" = "/" ]; then
    device="$1"
    mountpoint="$2"
    shift 2
else
    [ "$#" -ge 1 ] || die "usage: mount.fuse <device> <mountpoint> [-o <options>]"
    device="tidefs-preview"
    mountpoint="$1"
    shift
fi

while [ "$#" -gt 0 ]; do
    case "$1" in
        -o) [ "$#" -ge 2 ] || die "-o requires an argument"; mount_opts="$2"; shift 2 ;;
        --help|-h) echo "TideFS FUSE mount helper for xfstests" >&2; exit 0 ;;
        *) shift ;;
    esac
done

daemon_opts="${TIDEFS_XFSTESTS_DAEMON_OPTIONS:-atime,dev}"
if [ -n "${mount_opts:-}" ]; then
    old_ifs="$IFS"
    IFS=,
    for opt in $mount_opts; do
        case "$opt" in
            atime|strictatime|relatime|noatime)
                daemon_opts="$opt"
                ;;
            sync|async|dev|nodev)
                daemon_opts="$daemon_opts,$opt"
                ;;
        esac
    done
    IFS="$old_ifs"
fi

store_root="${TIDEFS_XFSTESTS_STORE_ROOT:-/tmp/tidefs-xfstests-store}"
mkdir -p "$store_root"

mount_tag="$(echo "$device" | tr -dc 'a-zA-Z0-9._-' | head -c 32)"
store_dir="$store_root/xfstests-${mount_tag}-$$"
mkdir -p "$store_dir"

tidefs_bin="${TIDEFS_BIN:-}"
[ -n "$tidefs_bin" ] || tidefs_bin="$(command -v tidefs-posix-filesystem-adapter-daemon 2>/dev/null || true)"
[ -n "$tidefs_bin" ] && [ -x "$tidefs_bin" ] || die "tidefs-posix-filesystem-adapter-daemon not found (set TIDEFS_BIN)"

debug "mountpoint=$mountpoint store=$store_dir tidefs=$tidefs_bin"
debug "daemon_opts=$daemon_opts"

[ -c /dev/fuse ] || modprobe fuse 2>/dev/null || true


# Build auth-key args.  The sanitised PATH from mount(8) strips
# TIDEFS_ROOT_AUTHENTICATION_KEY_HEX, so we also check a key file
# (env TIDEFS_ROOT_AUTH_KEY_FILE or /var/lib/tidefs/root-auth-key).
root_auth_args=()
_auth_key_file="${TIDEFS_ROOT_AUTH_KEY_FILE:-/var/lib/tidefs/root-auth-key}"
if [ -n "${TIDEFS_ROOT_AUTHENTICATION_KEY_HEX:-}" ]; then
    root_auth_args=(--root-auth-key-hex "$TIDEFS_ROOT_AUTHENTICATION_KEY_HEX")
elif [ -f "$_auth_key_file" ] && [ -r "$_auth_key_file" ]; then
    root_auth_args=(--root-auth-key-hex "$(head -c 64 "$_auth_key_file")")
fi
# tidefs-posix-filesystem-adapter-daemon mount (via fuser::mount2), daemonized
"$tidefs_bin" mount --store "$store_dir" --mount "$mountpoint" \
    --options "$daemon_opts" \
    "${root_auth_args[@]}" \
    &>"$store_dir/tidefs.log" &
tidefs_pid=$!
echo "$tidefs_pid" > "$store_dir/tidefs.pid"

# Wait for mountpoint (poll up to 30s)
for waited in $(seq 30); do
    if mountpoint -q "$mountpoint" 2>/dev/null; then
        debug "mountpoint ready after ${waited}s"
        disown "$tidefs_pid" 2>/dev/null || true
        exit 0
    fi
    kill -0 "$tidefs_pid" 2>/dev/null || { tail -20 "$store_dir/tidefs.log" 2>/dev/null >&2; die "tidefs daemon exited before mount became ready"; }
    sleep 1
done

kill "$tidefs_pid" 2>/dev/null || true
die "timeout waiting for mountpoint $mountpoint"
