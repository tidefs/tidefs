#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0-only WITH Linux-syscall-note
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  tidefs-scheduler-dirty-debt-runtime --output-dir DIR [OPTIONS]
  tidefs-scheduler-dirty-debt-runtime --input-artifact FILE \
    --input-summary FILE --input-manifest FILE --output-dir DIR \
    --run-id ID --source-ref SHA --generated-at TIMESTAMP

Run the existing Linux 7.0 FUSE QEMU smoke row and promote its raw local
queue-depth snapshot into the scheduler dirty-debt evidence shape. The
promoted artifact records the exact mounted workload and topology, the
queue data that was observed, and the scheduler-wide refusal boundaries
that keep scheduler.dirty_debt.no_hidden.v1 blocked.

By default this command launches scripts/tidefs-fuse-vm-test. The input mode
promotes files downloaded from a completed QEMU Smoke fuse-vm-test run without
launching another VM; a digest-matched version-2 runtime manifest must bind
the promoted input to its run provenance.

Options:
  --output-dir DIR       Write queue-depth-runtime.json and its claim manifests here
  --timeout SECONDS      QEMU timeout in run mode (default: 900)
  --input-artifact FILE  Existing raw queue-depth-runtime.json from QEMU Smoke
  --input-summary FILE   Matching fuse-vm-test.json from the same QEMU run
  --input-manifest FILE  Matching queue-depth-runtime.manifest.json that names and digests the input
  --run-id ID            Concrete run id (default: GitHub run or local QEMU id)
  --source-ref SHA       Exact 40-hex source commit (default: checkout HEAD)
  --generated-at TIME    UTC RFC3339 timestamp (default: current UTC time)
  --keep-runtime-output  Keep the owned temporary QEMU output in run mode
  --help, -h             Show this help
EOF
}

fail() {
  echo "tidefs-scheduler-dirty-debt-runtime: $*" >&2
  exit 2
}

content_digest_for_file() {
  local file="$1"
  local digest_hex

  if command -v b3sum >/dev/null 2>&1; then
    digest_hex="$(b3sum "$file" | awk '{print $1}')"
  else
    digest_hex="$(
      nix shell --inputs-from "$repo" nixpkgs#b3sum \
        --command b3sum "$file" | awk '{print $1}'
    )"
  fi
  printf 'blake3:%s\n' "$digest_hex"
}

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo="${TIDEFS_REPO:-$(cd -- "$script_dir/.." && pwd)}"
output_dir=""
timeout_seconds=900
input_artifact=""
input_summary=""
input_manifest=""
run_id="${TIDEFS_DIRTY_DEBT_RUN_ID:-}"
source_ref="${TIDEFS_DIRTY_DEBT_SOURCE_REF:-}"
generated_at="${TIDEFS_DIRTY_DEBT_GENERATED_AT:-}"
keep_runtime_output=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --output-dir)
      [[ $# -ge 2 ]] || fail "--output-dir requires an argument"
      output_dir="$2"
      shift 2
      ;;
    --timeout)
      [[ $# -ge 2 ]] || fail "--timeout requires an argument"
      timeout_seconds="$2"
      shift 2
      ;;
    --input-artifact)
      [[ $# -ge 2 ]] || fail "--input-artifact requires an argument"
      input_artifact="$2"
      shift 2
      ;;
    --input-summary)
      [[ $# -ge 2 ]] || fail "--input-summary requires an argument"
      input_summary="$2"
      shift 2
      ;;
    --input-manifest)
      [[ $# -ge 2 ]] || fail "--input-manifest requires an argument"
      input_manifest="$2"
      shift 2
      ;;
    --run-id)
      [[ $# -ge 2 ]] || fail "--run-id requires an argument"
      run_id="$2"
      shift 2
      ;;
    --source-ref)
      [[ $# -ge 2 ]] || fail "--source-ref requires an argument"
      source_ref="$2"
      shift 2
      ;;
    --generated-at)
      [[ $# -ge 2 ]] || fail "--generated-at requires an argument"
      generated_at="$2"
      shift 2
      ;;
    --keep-runtime-output)
      keep_runtime_output=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      fail "unknown argument: $1"
      ;;
  esac
done

[[ -n "$output_dir" ]] || fail "--output-dir is required"
[[ "$timeout_seconds" =~ ^[1-9][0-9]*$ ]] || fail "--timeout must be a positive integer"
command -v jq >/dev/null 2>&1 || fail "jq is required"
if ! command -v b3sum >/dev/null 2>&1 && ! command -v nix >/dev/null 2>&1; then
  fail "b3sum or Nix is required"
fi

input_mode=0
if [[ -n "$input_artifact" || -n "$input_summary" || -n "$input_manifest" ]]; then
  input_mode=1
  [[ -n "$input_artifact" && -n "$input_summary" && -n "$input_manifest" ]] \
    || fail "--input-artifact, --input-summary, and --input-manifest must be used together"
  [[ -n "$run_id" && -n "$source_ref" && -n "$generated_at" ]] \
    || fail "input mode requires --run-id, --source-ref, and --generated-at"
fi

if [[ -z "$generated_at" ]]; then
  generated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
fi
if [[ "$input_mode" -eq 0 ]]; then
  if [[ -n "$(git -C "$repo" status --porcelain --untracked-files=no)" ]]; then
    fail "run mode requires a checkout without staged or unstaged tracked changes"
  fi
  checkout_source_ref="$(git -C "$repo" rev-parse HEAD)"
  if [[ -n "$source_ref" && "$source_ref" != "$checkout_source_ref" ]]; then
    fail "--source-ref must match the run-mode checkout HEAD"
  fi
  source_ref="$checkout_source_ref"
  if [[ "${GITHUB_RUN_ID:-}" =~ ^[0-9]+$ ]] \
    && [[ "${GITHUB_RUN_ATTEMPT:-1}" =~ ^[1-9][0-9]*$ ]]; then
    expected_run_id="github-actions:${GITHUB_RUN_ID}/${GITHUB_RUN_ATTEMPT:-1}"
  else
    expected_run_id="local-qemu:${generated_at}"
  fi
  if [[ -n "$run_id" && "$run_id" != "$expected_run_id" ]]; then
    fail "--run-id must match the run-mode producer id $expected_run_id"
  fi
  run_id="$expected_run_id"
fi

[[ "$source_ref" =~ ^[0-9a-f]{40}$ ]] \
  || fail "--source-ref must be an exact lowercase 40-hex commit"
[[ "$generated_at" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$ ]] \
  || fail "--generated-at must use UTC RFC3339 form YYYY-MM-DDTHH:MM:SSZ"
case "${run_id,,}" in
  ""|unknown|none|unset|tbd|n/a)
    fail "--run-id must identify concrete runtime provenance"
    ;;
esac

owned_runtime_dir=""
artifact_tmp=""
manifest_tmp=""
local_manifest_tmp=""
cleanup() {
  [[ -z "$artifact_tmp" ]] || rm -f -- "$artifact_tmp"
  [[ -z "$manifest_tmp" ]] || rm -f -- "$manifest_tmp"
  [[ -z "$local_manifest_tmp" ]] || rm -f -- "$local_manifest_tmp"
  if [[ -n "$owned_runtime_dir" && "$keep_runtime_output" -eq 0 ]]; then
    rm -rf -- "$owned_runtime_dir"
  elif [[ -n "$owned_runtime_dir" ]]; then
    echo "runtime_output=$owned_runtime_dir"
  fi
}
trap cleanup EXIT

if [[ "$input_mode" -eq 0 ]]; then
  owned_runtime_dir="$(mktemp -d "${TMPDIR:-/tmp}/tidefs-dirty-debt-runtime.XXXXXX")"
  input_artifact="$owned_runtime_dir/performance/queue-depth-runtime.json"
  input_summary="$owned_runtime_dir/fuse-vm-test.json"
  input_manifest="$owned_runtime_dir/queue-depth-runtime.manifest.json"
  GITHUB_SHA="$source_ref" \
    GITHUB_RUN_ID="${GITHUB_RUN_ID:-local-qemu}" \
    GITHUB_RUN_ATTEMPT="${GITHUB_RUN_ATTEMPT:-1}" \
    TIDEFS_GENERATED_AT="$generated_at" \
    "$script_dir/tidefs-fuse-vm-test" \
      --timeout "$timeout_seconds" \
      --validation-dir "$owned_runtime_dir" \
      --queue-depth-artifact "$input_artifact"
fi

[[ -s "$input_artifact" ]] || fail "queue-depth input is missing or empty: $input_artifact"
[[ -s "$input_summary" ]] || fail "QEMU summary is missing or empty: $input_summary"
[[ -s "$input_manifest" ]] || fail "QEMU input manifest is missing or empty: $input_manifest"

jq -e '
  .test == "tidefs-fuse-vm-test"
  and .version == 4
  and .tier == "outside-sandbox-qemu-guest"
  and .kernel_package == "linuxKernel_7_0"
  and (.kernel_version | type == "string" and test("^7\\.0([.-]|$)"))
  and .qemu_status == 0
  and (.done_marker_seen | type == "number" and floor == . and . >= 1)
  and (.passed | type == "number" and floor == . and . > 0)
  and .product_failures == 0
  and .environment_refusals == 0
  and .queue_depth_artifact_present == true
' "$input_summary" >/dev/null \
  || fail "QEMU summary does not describe a passing Linux 7.0 fuse-vm-test row"

jq -e '
  .schema_version == 1
  and .evidence_class == "queue-depth-runtime-artifact"
  and .source == "tidefs-posix-filesystem-adapter-daemon smoke-mount"
  and .claim_ids == ["perf.local.no_unbounded_dirty_debt.v1"]
  and .workload == "fuse-smoke-mount-quick"
  and .mount_adapter == "fuse"
  and .pool == "root"
  and ([
    .admission.current_dirty_bytes,
    .admission.current_dirty_ops,
    .admission.current_outstanding_permits,
    .admission.current_tick,
    .admission.peak_dirty_bytes,
    .admission.peak_dirty_ops,
    .admission.peak_outstanding_permits
  ] | all(type == "number" and floor == . and . >= 0))
  and ([
    .hard_caps.dirty_age_ticks,
    .hard_caps.dirty_bytes,
    .hard_caps.dirty_ops,
    .hard_caps.permits,
    .effective_caps.dirty_age_ticks,
    .effective_caps.dirty_bytes,
    .effective_caps.dirty_ops,
    .effective_caps.permits
  ] | all(type == "number" and floor == . and . > 0))
  and ([
    .invariant_checks.current_dirty_bytes_within_effective_cap,
    .invariant_checks.current_dirty_ops_within_effective_cap,
    .invariant_checks.current_outstanding_permits_within_hard_cap,
    .invariant_checks.peak_dirty_bytes_within_effective_cap,
    .invariant_checks.peak_dirty_ops_within_effective_cap,
    .invariant_checks.peak_outstanding_permits_within_hard_cap
  ] | all(. == true))
  and .admission.peak_dirty_bytes >= .admission.current_dirty_bytes
  and .admission.peak_dirty_ops >= .admission.current_dirty_ops
  and .admission.peak_outstanding_permits >= .admission.current_outstanding_permits
  and .admission.peak_dirty_bytes <= .effective_caps.dirty_bytes
  and .admission.peak_dirty_ops <= .effective_caps.dirty_ops
  and .admission.peak_outstanding_permits <= .hard_caps.permits
  and .effective_caps.dirty_age_ticks <= .hard_caps.dirty_age_ticks
  and .effective_caps.dirty_bytes <= .hard_caps.dirty_bytes
  and .effective_caps.dirty_ops <= .hard_caps.dirty_ops
  and .effective_caps.permits <= .hard_caps.permits
  and .determinism.workload == "fixed smoke-mount quick workload"
  and (.determinism.admission_state | type == "string" and length > 0)
  and ([
    .determinism.tolerance.peak_dirty_bytes,
    .determinism.tolerance.peak_dirty_ops,
    .determinism.tolerance.peak_outstanding_permits
  ] | all(type == "number" and floor == . and . >= 0))
  and .no_hidden_queue_gate.registry_path == "validation/performance/no-hidden-queues.toml"
  and .no_hidden_queue_gate.command == "cargo run -p tidefs-xtask -- check-no-hidden-queues"
  and (.no_hidden_queue_gate.registered_queue_roots | type == "array")
  and (.no_hidden_queue_gate.registered_queue_roots | index("performance_contract.budgeted_queue") != null)
  and (.no_hidden_queue_gate.registered_queue_roots | index("local_fs.write_admission") != null)
' "$input_artifact" >/dev/null \
  || fail "queue-depth input is not a passing fuse-smoke-mount-quick runtime snapshot"

input_content_digest="$(content_digest_for_file "$input_artifact")"
jq -e \
  --arg content_digest "$input_content_digest" \
  --arg source_ref "$source_ref" \
  --arg run_id "$run_id" \
  --arg generated_at "$generated_at" '
      (keys | sort) == [
        "artifact_path",
        "blocking_issues",
        "claim_id",
        "content_digest",
        "evidence_class",
        "generated_at",
        "manifest_version",
        "outcome",
        "residual_risk",
        "run_id",
        "scope",
        "source",
        "source_ref",
        "validation_tier"
      ]
      and .manifest_version == 2
      and .claim_id == "perf.local.no_unbounded_dirty_debt.v1"
      and .evidence_class == "queue-depth-runtime-artifact"
      and .validation_tier == "mounted-userspace"
      and .artifact_path == "validation/artifacts/performance/queue-depth-runtime.json"
      and (.content_digest | type == "string" and test("^blake3:[0-9a-f]{64}$"))
      and .content_digest == $content_digest
      and (.run_id | type == "string" and length > 0)
      and .run_id == $run_id
      and (.source_ref | type == "string" and test("^[0-9a-f]{40}$"))
      and .source_ref == $source_ref
      and .outcome == "pass"
      and (.scope | type == "string" and length > 0)
      and (.residual_risk | type == "string" and length > 0)
      and .source == "qemu-smoke-fuse-vm-test"
      and (.generated_at | type == "string" and test("^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"))
      and .generated_at == $generated_at
      and .blocking_issues == []
  ' "$input_manifest" >/dev/null \
  || fail "QEMU input manifest does not bind this artifact to the requested passing runtime provenance"

mkdir -p -- "$output_dir"
artifact_path="$output_dir/queue-depth-runtime.json"
manifest_path="$output_dir/scheduler-dirty-debt-queue-depth-runtime.manifest.json"
local_manifest_path="$output_dir/local-no-unbounded-dirty-debt-queue-depth-runtime.manifest.json"
artifact_tmp="$artifact_path.tmp.$$"
manifest_tmp="$manifest_path.tmp.$$"
local_manifest_tmp="$local_manifest_path.tmp.$$"

jq --sort-keys \
  --arg source_ref "$source_ref" \
  --arg run_id "$run_id" \
  --arg generated_at "$generated_at" \
  --slurpfile summary "$input_summary" '
  {
    schema_version: 2,
    evidence_class: "queue-depth-runtime-artifact",
    artifact_path: "validation/artifacts/performance/queue-depth-runtime.json",
    artifact_outcome: "partial-coverage",
    claim_ids: [
      "scheduler.dirty_debt.no_hidden.v1",
      "perf.local.no_unbounded_dirty_debt.v1"
    ],
    scheduler_claim_status: "blocked",
    source: "qemu-smoke-fuse-vm-test",
    source_ref: $source_ref,
    run_id: $run_id,
    generated_at: $generated_at,
    workload: .workload,
    workload_detail: {
      profile: "quick",
      command: "scripts/tidefs-scheduler-dirty-debt-runtime --output-dir <artifact-dir>",
      operations: [
        "mounted root stat",
        "file create, write, read, and append",
        "directory create and readdir",
        "symlink create and readlink",
        "file unlink and directory removal",
        "file rename"
      ]
    },
    topology: {
      node_count: 1,
      mounted_filesystem_count: 1,
      mount_adapter: .mount_adapter,
      pool: .pool,
      kernel_version: $summary[0].kernel_version,
      runtime_tier: $summary[0].tier,
      transport: "none",
      distributed_peer_count: 0,
      background_scrub: "disabled"
    },
    scope: {
      result: "bounded-local-admission-observed",
      measured: [
        "aggregate local dirty-write and metadata admission usage",
        "hard and effective admission caps",
        "mounted quick-workload admission invariants"
      ],
      scheduler_wide_result: "refused-incomplete"
    },
    queue_observations: [
      {
        queue_root: "performance_contract.budgeted_queue",
        status: "observed-through-local-write-admission",
        work_classes: ["foreground-write", "metadata-mutation"]
      },
      {
        queue_root: "local_fs.write_admission",
        status: "measured-aggregate",
        work_classes: ["foreground-write", "metadata-mutation"],
        admission: .admission,
        hard_caps: .hard_caps,
        effective_caps: .effective_caps,
        invariant_checks: .invariant_checks
      }
    ],
    refusal_boundaries: [
      {
        area: "writeback",
        status: "not-independently-observed",
        reason: "the row does not emit separate write-buffer, dirty-set, or dirty-page-tracker depth peaks"
      },
      {
        area: "page-cache",
        status: "not-independently-observed",
        reason: "the row does not emit page-cache LRU depth or dirty-page eligibility counters"
      },
      {
        area: "reclaim",
        status: "not-independently-observed",
        reason: "the row does not emit local or durable reclaim queue depth or drain counters"
      },
      {
        area: "scrub-repair",
        status: "not-exercised",
        reason: "background scrub is disabled in the quick mounted topology"
      },
      {
        area: "rename-orphan-index",
        status: "exercised-without-attributed-depth",
        reason: "rename and unlink run through the mount, but the aggregate admission snapshot cannot attribute queue depth to orphan-index work"
      },
      {
        area: "transport-distributed",
        status: "out-of-topology",
        reason: "the single-node local mount has no peer or transport queue"
      },
      {
        area: "background-scheduler",
        status: "not-independently-observed",
        reason: "the row does not emit registered-service depths, cycle counts, or per-service processed work"
      },
      {
        area: "compaction-defrag-cleaner",
        status: "not-exercised",
        reason: "the quick workload does not schedule or instrument these maintenance queues"
      }
    ],
    admission: .admission,
    hard_caps: .hard_caps,
    effective_caps: .effective_caps,
    invariant_checks: .invariant_checks,
    determinism: .determinism,
    no_hidden_queue_gate: .no_hidden_queue_gate,
    qemu_row: {
      passed: $summary[0].passed,
      done_marker_seen: $summary[0].done_marker_seen,
      product_failures: $summary[0].product_failures,
      environment_refusals: $summary[0].environment_refusals
    },
    non_claims: [
      "does not prove scheduler-wide foreground and background dirty-debt coverage",
      "does not validate crash recovery, fsync durability, or mmap/writeback coherency",
      "does not validate kernel, RDMA, distributed, production, release, or successor/comparator behavior",
      "does not move scheduler.dirty_debt.no_hidden.v1 or perf.local.no_unbounded_dirty_debt.v1 out of blocked status"
    ]
  }
' "$input_artifact" > "$artifact_tmp"

content_digest="$(content_digest_for_file "$artifact_tmp")"
write_output_manifest() {
  local destination="$1"
  local claim_id="$2"
  local scope="$3"
  local residual_risk="$4"

  jq -n --sort-keys \
    --arg claim_id "$claim_id" \
    --arg scope "$scope" \
    --arg residual_risk "$residual_risk" \
    --arg content_digest "$content_digest" \
    --arg source_ref "$source_ref" \
    --arg run_id "$run_id" \
    --arg generated_at "$generated_at" '
  {
    manifest_version: 2,
    claim_id: $claim_id,
    evidence_class: "queue-depth-runtime-artifact",
    validation_tier: "mounted-userspace",
    scope: $scope,
    artifact_path: "validation/artifacts/performance/queue-depth-runtime.json",
    content_digest: $content_digest,
    run_id: $run_id,
    source_ref: $source_ref,
    outcome: "pass",
    residual_risk: $residual_risk,
    source: "scripts/tidefs-scheduler-dirty-debt-runtime via qemu-smoke-fuse-vm-test",
    generated_at: $generated_at,
    blocking_issues: []
  }
  ' > "$destination"
}

write_output_manifest \
  "$manifest_tmp" \
  "scheduler.dirty_debt.no_hidden.v1" \
  "Linux 7.0 QEMU mounted FUSE quick workload with aggregate local admission measurements and explicit scheduler-wide refusal boundaries" \
  "The row measures bounded aggregate local admission only. Independent writeback, page-cache, reclaim, scrub/repair, rename/orphan-index, transport/distributed, and background-scheduler queue-depth coverage remains absent, so scheduler.dirty_debt.no_hidden.v1 stays blocked."
write_output_manifest \
  "$local_manifest_tmp" \
  "perf.local.no_unbounded_dirty_debt.v1" \
  "Linux 7.0 QEMU mounted FUSE quick workload with aggregate local admission measurements" \
  "The row refreshes bounded aggregate local admission evidence only. The artifact explicitly keeps perf.local.no_unbounded_dirty_debt.v1 blocked and does not establish scheduler-wide, crash-recovery, fsync, mmap/writeback, kernel, RDMA, distributed, production, or release behavior."

mv -- "$artifact_tmp" "$artifact_path"
mv -- "$manifest_tmp" "$manifest_path"
mv -- "$local_manifest_tmp" "$local_manifest_path"
artifact_tmp=""
manifest_tmp=""
local_manifest_tmp=""

echo "artifact=$artifact_path"
echo "manifest=$manifest_path"
echo "local_manifest=$local_manifest_path"
echo "source_ref=$source_ref"
echo "run_id=$run_id"
