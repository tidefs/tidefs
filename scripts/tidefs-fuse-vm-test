#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: tidefs-fuse-vm-test [RUNNER OPTIONS...]

Build the Nix artifacts for the FUSE VM test, then launch QEMU outside the
Nix build sandbox.

Runner options passed through to the built runner include:
  --timeout SECONDS
  --validation-dir DIR
  --queue-depth-artifact PATH
  --ack-receipt-runtime
  --data-shape-runtime
  --scrub-foreground-read
  --keep-tmp

Build options consumed by this launcher:
  --system SYSTEM
  --max-jobs N
  --cores N
  --root-dir DIR
  --build-dir DIR
  --nofile-limit N
  --build-timeout SECONDS
  --no-warm-kernel
  --launcher-help
EOF
}

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo="${TIDEFS_REPO:-$(cd -- "$script_dir/.." && pwd)}"
system="${TIDEFS_NIX_SYSTEM:-x86_64-linux}"
home_dir="${HOME:-/root}"
state_home="${XDG_STATE_HOME:-$home_dir/.local/state}"
root_dir="${TIDEFS_NIX_QEMU_ROOT_DIR:-$state_home/tidefs/nix-qemu-roots}"
build_args=()
runner_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --launcher-help)
      usage
      exit 0
      ;;
    --system)
      [[ $# -ge 2 ]] || { echo "--system requires an argument" >&2; exit 2; }
      system="$2"
      shift 2
      ;;
    --max-jobs|--cores|--build-dir|--nofile-limit)
      [[ $# -ge 2 ]] || { echo "$1 requires an argument" >&2; exit 2; }
      build_args+=("$1" "$2")
      shift 2
      ;;
    --root-dir)
      [[ $# -ge 2 ]] || { echo "--root-dir requires an argument" >&2; exit 2; }
      root_dir="$2"
      shift 2
      ;;
    --build-timeout)
      [[ $# -ge 2 ]] || { echo "--build-timeout requires an argument" >&2; exit 2; }
      build_args+=("--timeout" "$2")
      shift 2
      ;;
    --no-warm-kernel)
      build_args+=("$1")
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      runner_args+=("$@")
      break
      ;;
    *)
      runner_args+=("$1")
      shift
      ;;
  esac
done

verified_source_ref=""
source_checkout=""
source_snapshot=""
run_root_dir=""
build_script="$script_dir/tidefs-nix-qemu-build"
cleanup_source_snapshot() {
  if [[ -n "$source_snapshot" ]]; then
    rm -rf -- "$source_snapshot"
    source_snapshot=""
  fi
}
cleanup_launcher() {
  cleanup_source_snapshot
  if [[ -n "$run_root_dir" ]]; then
    rm -rf -- "$run_root_dir"
    run_root_dir=""
  fi
}
trap cleanup_launcher EXIT

if git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  source_checkout="$repo"
elif [[ "${GITHUB_ACTIONS:-}" == "true" ]]; then
  source_checkout="${GITHUB_WORKSPACE:-}"
  if [[ -z "$source_checkout" ]] \
    || ! git -C "$source_checkout" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "tidefs-fuse-vm-test: GitHub Actions checkout is unavailable for source verification" >&2
    exit 2
  fi
fi
if [[ -n "$source_checkout" ]]; then
  if [[ -n "$(git -C "$source_checkout" status --porcelain --untracked-files=no)" ]]; then
    echo "tidefs-fuse-vm-test: promotable runs require a checkout without staged or unstaged tracked changes" >&2
    exit 2
  fi
  checkout_source_ref="$(git -C "$source_checkout" rev-parse HEAD)"
  if [[ -n "${GITHUB_SHA:-}" && "$GITHUB_SHA" != "$checkout_source_ref" ]]; then
    echo "tidefs-fuse-vm-test: GITHUB_SHA must match checkout HEAD" >&2
    exit 2
  fi
  GITHUB_SHA="$checkout_source_ref"
  verified_source_ref="$checkout_source_ref"
  command -v tar >/dev/null 2>&1 \
    || { echo "tidefs-fuse-vm-test: tar is required to snapshot the verified source" >&2; exit 2; }
  # Freeze the Nix input at the verified commit before the long build and VM run.
  source_snapshot="$(mktemp -d "${TMPDIR:-/tmp}/tidefs-fuse-vm-source.XXXXXX")"
  git -C "$source_checkout" archive --format=tar "$checkout_source_ref" \
    | tar -x -C "$source_snapshot"
  [[ -f "$source_snapshot/flake.nix" ]] \
    || { echo "tidefs-fuse-vm-test: verified source snapshot is not a TideFS flake" >&2; exit 2; }
  repo="$source_snapshot"
  build_script="$source_snapshot/scripts/tidefs-nix-qemu-build"
fi
export GITHUB_SHA
export TIDEFS_FUSE_VM_TEST_VERIFIED_SOURCE_REF="$verified_source_ref"
# Keep this launch's closure rooted independently until its runner exits.
mkdir -p "$root_dir"
run_root_dir="$(mktemp -d "$root_dir/.tidefs-fuse-vm-run.XXXXXX")"

bash "$build_script" \
  --target tidefsFuseVmTest \
  --name tidefs-fuse-vm-test \
  --repo "$repo" \
  --system "$system" \
  --root-dir "$run_root_dir" \
  "${build_args[@]}"

cleanup_source_snapshot

runner="$run_root_dir/tidefs-fuse-vm-test/bin/tidefs-fuse-vm-test-runner"
if [[ ! -x "$runner" ]]; then
  echo "tidefs-fuse-vm-test: built runner not found: $runner" >&2
  exit 2
fi

if "$runner" "${runner_args[@]}"; then
  runner_status=0
else
  runner_status=$?
fi
cleanup_launcher
trap - EXIT
exit "$runner_status"
