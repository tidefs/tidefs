#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: tidefs-fuse-writeback-cache-validation [HARNESS OPTIONS...]

Source launcher for the FUSE writeback-cache QEMU validation harness.
It evaluates the fast harness text and executes it directly, avoiding a Nix
build phase during harness-only edit loops.

Common harness options:
  --daemon-bin PATH    Already-built tidefs-posix-filesystem-adapter-daemon
  --kernel-img PATH    Already-built Linux 7.0 bzImage
  --module-dir DIR     Optional module directory when FUSE is modular
  --validation-dir DIR   Write boot logs and summary
  --timeout SECONDS    Per-boot timeout
  --help, -h           Show the harness help
EOF
}

if [[ "${1:-}" == "--launcher-help" ]]; then
  usage
  exit 0
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo="${TIDEFS_REPO:-$(cd -- "$script_dir/.." && pwd)}"
system="${TIDEFS_NIX_SYSTEM:-x86_64-linux}"
attr="${TIDEFS_FUSE_WBC_FAST_ATTR:-packages.${system}.fuseWritebackCacheValidationFast}"

tmp_dir="${TMPDIR:-/tmp}/tidefs-fuse-writeback-cache-launcher.$$"
mkdir -p "$tmp_dir"
cleanup() {
  rm -rf "$tmp_dir"
}
trap cleanup EXIT

harness="$tmp_dir/tidefs-fuse-writeback-validation"
nix eval "${repo}#${attr}.text" --raw > "$harness"
chmod +x "$harness"

exec "$harness" "$@"
